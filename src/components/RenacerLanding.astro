<script>
  const initReveal = () => {
    const revealItems = Array.from(document.querySelectorAll('.reveal-item'));
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.12,
        rootMargin: '0px 0px -6% 0px',
      }
    );

    revealItems.forEach((item) => observer.observe(item));
  };

  const startReveal = () => {
    requestAnimationFrame(() => {
      requestAnimationFrame(initReveal);
    });
  };

  const initHeroPointer = () => {
    const hero = document.querySelector('.hero');
    if (!hero || window.matchMedia('(pointer: coarse)').matches) return;
    const flights = Array.from(hero.querySelectorAll('.hero-flight'));
    if (!flights.length || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let pointerX = null;
    let pointerY = null;

    const states = flights.map((flight, index) => {
      const style = getComputedStyle(flight);
      const left = Number.parseFloat(style.left || '0');
      const top = Number.parseFloat(style.top || '0');
      const width = flight.offsetWidth || 160;
      const height = flight.offsetHeight || 96;
      const scale = Number.parseFloat(style.getPropertyValue('--flight-scale') || '0.9');

      return {
        el: flight,
        homeX: left,
        homeY: top,
        x: left,
        y: top,
        vx: 0,
        vy: 0,
        width,
        height,
        scale,
        ampX: 10 + index * 3,
        ampY: 8 + index * 2,
        phase: index * 1.7,
        speed: 0.001 + index * 0.00018,
      };
    });

    const renderFlights = (time) => {
      const heroRect = hero.getBoundingClientRect();

      states.forEach((state) => {
        let ax = (state.homeX - state.x) * 0.0045;
        let ay = (state.homeY - state.y) * 0.0045;

        if (pointerX !== null && pointerY !== null) {
          const centerX = heroRect.left + state.x + state.width / 2;
          const centerY = heroRect.top + state.y + state.height / 2;
          const dx = centerX - pointerX;
          const dy = centerY - pointerY;
          const distance = Math.max(Math.hypot(dx, dy), 1);
          const directionX = dx / distance;
          const directionY = dy / distance;
          const influence = 0.12 + Math.max(0, 1 - Math.min(distance, 560) / 560) * 0.22;

          ax += directionX * influence;
          ay += directionY * influence * 0.78;
        }

        state.vx = state.vx * 0.92 + ax;
        state.vy = state.vy * 0.92 + ay;
        state.x += state.vx;
        state.y += state.vy;

        const maxXOffset = 96;
        const maxYOffset = 58;
        state.x = Math.min(state.homeX + maxXOffset, Math.max(state.homeX - maxXOffset, state.x));
        state.y = Math.min(state.homeY + maxYOffset, Math.max(state.homeY - maxYOffset, state.y));

        const floatX = Math.sin(time * state.speed + state.phase) * state.ampX;
        const floatY = Math.cos(time * state.speed * 0.9 + state.phase) * state.ampY;
        const opacity = 0.11 + (Math.sin(time * state.speed + state.phase) + 1) * 0.055;

        state.el.style.transform =
          `translate3d(${(state.x - state.homeX + floatX).toFixed(2)}px, ${(state.y - state.homeY + floatY).toFixed(2)}px, 0) scale(${state.scale})`;
        state.el.style.opacity = opacity.toFixed(3);
      });

      requestAnimationFrame(renderFlights);
    };

    const setPointer = (event) => {
      const rect = hero.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;
      pointerX = event.clientX;
      pointerY = event.clientY;
      hero.style.setProperty('--pointer-x', `${x}%`);
      hero.style.setProperty('--pointer-y', `${y}%`);
      hero.style.setProperty('--orb-shift-x', `${(x - 50) * 0.18}px`);
      hero.style.setProperty('--orb-shift-y', `${(y - 50) * 0.12}px`);
    };

    hero.addEventListener('pointermove', setPointer);

    flights.forEach((flight, index) => {
      flight.addEventListener('pointerdown', (event) => {
        event.preventDefault();
        event.stopPropagation();

        const state = states[index];
        const birdRect = flight.getBoundingClientRect();
        const birdX = birdRect.left + birdRect.width / 2;
        const birdY = birdRect.top + birdRect.height / 2;
        const dx = birdX - event.clientX;
        const dy = birdY - event.clientY;
        const distance = Math.max(Math.hypot(dx, dy), 1);

        state.vx += (dx / distance) * 7.5;
        state.vy += (dy / distance) * 5.5;
      });
    });

    hero.addEventListener('pointerleave', () => {
      pointerX = null;
      pointerY = null;
      hero.style.setProperty('--pointer-x', '64%');
      hero.style.setProperty('--pointer-y', '32%');
      hero.style.setProperty('--orb-shift-x', '0px');
      hero.style.setProperty('--orb-shift-y', '0px');
    });

    requestAnimationFrame(renderFlights);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      startReveal();
      initHeroPointer();
    }, { once: true });
  } else {
    startReveal();
    initHeroPointer();
  }

</script>

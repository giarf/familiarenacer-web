---
import LucideIcon from './LucideIcon.astro';

const donationLinks = [
  {
    name: 'Gesto Solidario',
    amount: 'CLP 1.000 a CLP 4.000',
    description: 'Un pequeño gesto que también ayuda a sembrar esperanza.',
    icon: 'HeartHandshake',
    href: 'https://app.reveniu.com/checkout-custom-link/tDRHQvX1T0JL1gdx8A7S0mM4RFqV25AR',
  },
  {
    name: 'Semilla Solidaria',
    amount: '$5.000',
    description: 'Inicia la ayuda y permite sembrar nuevas oportunidades.',
    icon: 'Sprout',
    href: 'https://app.reveniu.com/checkout-custom-link/95bH9li3iYcdJKxuugTd1NV2s7n5sglH',
  },
  {
    name: 'Brote de Esperanza',
    amount: '$10.000',
    description: 'Ayuda a que nuevos proyectos comiencen a crecer.',
    icon: 'Leaf',
    href: 'https://app.reveniu.com/checkout-custom-link/jwtYOw0vQOk5QyWXg8Zps9t6HMBfksmY',
  },
  {
    name: 'Árbol de Apoyo',
    amount: '$20.000',
    description: 'Fortalece el acompañamiento a niños y familias.',
    icon: 'Users',
    href: 'https://app.reveniu.com/checkout-custom-link/dZEYJhCPUUQwOU8zqfYtsIIkGLpPPFsD',
  },
  {
    name: 'Sol Solidario',
    amount: '$30.000',
    description: 'Entrega la energía que permite que todo siga creciendo.',
    icon: 'SunMedium',
    href: 'https://app.reveniu.com/checkout-custom-link/ayAQljPMkfiwbl8FOEl9SIBXU1u8wRhK',
  },
  {
    name: 'Raíz Fundadora',
    amount: '$40.000',
    description: 'Sostiene y da estabilidad al proyecto.',
    icon: 'BadgeCheck',
    href: 'https://app.reveniu.com/checkout-custom-link/kX0o2VEFugphajKBGUDhQEUew9YqYDtt',
  },
  {
    name: 'Guardián de Renacer',
    amount: '$50.000 o más',
    description: 'Protege y cuida el futuro del centro y de quienes lo necesitan.',
    icon: 'ShieldCheck',
    href: 'https://app.reveniu.com/checkout-custom-link/feN8IRS5PRiC2gC0XKqhwyBTus342V0d',
  },
];
---

<main class="donations-page">
  <div class="donations-shell">
    <section class="donations-content">
      <div class="content-heading">
        <a href="/" class="back-link">← Volver a Renacer</a>
        <p class="eyebrow">Formas de aportar</p>
        <h2>Escoge la opción que mejor se ajuste a tu compromiso.</h2>
        <p class="content-scale">Ordenado de menor a mayor aporte mensual.</p>
      </div>

      <div class="links-grid">
        {donationLinks.map((item) => (
          <a
            class="donation-card"
            href={item.href}
            target="_blank"
            rel="nofollow sponsored noopener noreferrer"
          >
            <div class="card-icon">
              <LucideIcon name={item.icon} size={22} />
            </div>

            <div class="card-copy">
              <strong>{item.name}</strong>
              <small>{item.description}</small>
            </div>

            <div class="card-meta">
              <span class="card-amount">{item.amount}</span>
            </div>

            <span class="card-arrow">
              <LucideIcon name="ArrowUpRight" size={18} />
            </span>
          </a>
        ))}
      </div>

      <p class="footnote">
        Si tienes dudas sobre aportes, coordinación institucional o donaciones directas, escríbenos
        a `contacto@familiarenacer.cl`.
      </p>
    </section>
  </div>
</main>

<style>
  .donations-page {
    min-height: 100vh;
    padding: 1.5rem;
    background:
      radial-gradient(circle at 10% 10%, rgba(8, 52, 183, 0.14), transparent 20%),
      radial-gradient(circle at 88% 18%, rgba(60, 118, 255, 0.12), transparent 18%),
      linear-gradient(180deg, #eef4ff 0%, #f7faff 40%, #eef4ff 100%);
  }

  .donations-shell {
    width: min(100%, 760px);
    margin: 0 auto;
  }

  .donations-content {
    border-radius: 1.7rem;
    border: 1px solid rgba(18, 63, 184, 0.12);
    background: rgba(255, 255, 255, 0.84);
    backdrop-filter: blur(14px);
    box-shadow: 0 18px 42px rgba(16, 46, 120, 0.08);
  }

  .donations-content {
    padding: 1.35rem;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1rem;
    color: #47649a;
    font-weight: 700;
    text-decoration: none;
  }

  .brand-badge,
  .eyebrow {
    display: inline-flex;
    width: fit-content;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    background: rgba(8, 52, 183, 0.08);
    color: #0834b7;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h2,
  strong {
    font-family: 'Sora', sans-serif;
    letter-spacing: -0.04em;
    color: #122756;
  }

  .intro,
  .footnote,
  .card-copy small {
    color: #5e6f8d;
    line-height: 1.65;
  }

  .content-heading h2 {
    margin-top: 0.55rem;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 0.98;
    max-width: 12ch;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .content-scale {
    margin: 0.7rem 0 0;
    color: #4a6796;
    font-size: 0.92rem;
    font-weight: 700;
    text-align: center;
  }

  .content-heading {
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .links-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    margin-top: 1.35rem;
  }

  .donation-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    border: 1px solid rgba(18, 63, 184, 0.1);
    background: linear-gradient(180deg, #ffffff 0%, #f4f8ff 100%);
    box-shadow: 0 12px 28px rgba(18, 54, 144, 0.06);
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .donation-card:hover {
    transform: translateY(-2px);
    border-color: rgba(8, 52, 183, 0.22);
    background: linear-gradient(180deg, #ffffff 0%, #eaf1ff 100%);
    box-shadow: 0 18px 34px rgba(8, 52, 183, 0.12);
  }

  .card-icon {
    width: 2.7rem;
    height: 2.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: radial-gradient(circle at 30% 30%, rgba(86, 135, 255, 0.24), rgba(8, 52, 183, 0.1));
    color: #0834b7;
    transition:
      background 180ms ease,
      color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .card-icon :global(svg) {
    transition: color 180ms ease, transform 180ms ease;
  }

  .donation-card:hover .card-icon,
  .card-icon:hover {
    background: #0834b7;
    color: #ffffff;
    transform: scale(1.04);
    box-shadow: 0 14px 24px rgba(8, 52, 183, 0.22);
  }

  .donation-card:hover .card-icon :global(svg),
  .card-icon:hover :global(svg) {
    color: #ffffff;
  }

  .card-copy {
    display: grid;
    gap: 0.25rem;
  }

  .card-copy strong {
    font-size: 0.98rem;
  }

  .card-amount {
    color: #0834b7;
    font-weight: 800;
    font-size: 1.05rem;
  }

  .card-copy small {
    font-size: 0.83rem;
  }

  .card-meta {
    display: inline-grid;
    justify-items: end;
    gap: 0;
    text-align: right;
  }

  .card-arrow {
    color: #0834b7;
    transition: transform 180ms ease, color 180ms ease;
  }

  .donation-card:hover .card-arrow {
    transform: translate(2px, -2px);
  }

  .footnote {
    margin: 1.2rem 0 0;
    font-size: 0.86rem;
    text-align: center;
  }

  @media (max-width: 980px) {
    .donations-shell {
      width: 100%;
    }
  }

  @media (max-width: 520px) {
    .donations-page {
      padding: 0.85rem;
    }

    .donations-content {
      padding: 1.1rem;
      border-radius: 1.35rem;
    }

    .donation-card {
      grid-template-columns: auto 1fr auto;
      align-items: start;
    }

    .card-meta {
      grid-column: 2;
      justify-items: start;
      text-align: left;
      margin-top: 0.2rem;
    }
  }
</style>
